# Simplicity-Light Openbox Theme
# Compatible with: Openbox window manager
# Distros: All major Linux distributions with Openbox/LXDE/LXQt

# Window active colors
window.active.title.bg: flat
window.active.title.bg.color: #ebebeb
window.active.title.border.color: #5294e2
window.active.title.shadow.color: #d0d0d0
window.active.label.bg: flat
window.active.label.bg.color: #ebebeb
window.active.label.text.color: #2d2d2d
window.active.handle.bg: flat
window.active.handle.bg.color: #ebebeb
window.active.grip.bg: flat
window.active.grip.bg.color: #5294e2
window.active.border.color: #5294e2

# Window inactive colors
window.inactive.title.bg: flat
window.inactive.title.bg.color: #f0f0f0
window.inactive.title.border.color: #d0d0d0
window.inactive.title.shadow.color: #d8d8d8
window.inactive.label.bg: flat
window.inactive.label.bg.color: #f0f0f0
window.inactive.label.text.color: #909090
window.inactive.handle.bg: flat
window.inactive.handle.bg.color: #f0f0f0
window.inactive.grip.bg: flat
window.inactive.grip.bg.color: #d0d0d0
window.inactive.border.color: #d0d0d0

# Button colors (active)
window.active.button.unpressed.bg: flat
window.active.button.unpressed.bg.color: #ebebeb
window.active.button.unpressed.image.color: #2d2d2d
window.active.button.pressed.bg: flat
window.active.button.pressed.bg.color: #d0d0d0
window.active.button.pressed.image.color: #1a1a1a
window.active.button.hover.bg: flat
window.active.button.hover.bg.color: #dcdcdc
window.active.button.hover.image.color: #1a1a1a
window.active.button.disabled.bg: flat
window.active.button.disabled.bg.color: #ebebeb
window.active.button.disabled.image.color: #b0b0b0
window.active.button.toggled.unpressed.bg: flat
window.active.button.toggled.unpressed.bg.color: #dcdcdc
window.active.button.toggled.unpressed.image.color: #2d2d2d
window.active.button.toggled.pressed.bg: flat
window.active.button.toggled.pressed.bg.color: #d0d0d0
window.active.button.toggled.pressed.image.color: #1a1a1a
window.active.button.toggled.hover.bg: flat
window.active.button.toggled.hover.bg.color: #d4d4d4
window.active.button.toggled.hover.image.color: #1a1a1a

# Button colors (inactive)
window.inactive.button.unpressed.bg: flat
window.inactive.button.unpressed.bg.color: #f0f0f0
window.inactive.button.unpressed.image.color: #909090
window.inactive.button.pressed.bg: flat
window.inactive.button.pressed.bg.color: #e0e0e0
window.inactive.button.pressed.image.color: #707070
window.inactive.button.hover.bg: flat
window.inactive.button.hover.bg.color: #e8e8e8
window.inactive.button.hover.image.color: #707070
window.inactive.button.disabled.bg: flat
window.inactive.button.disabled.bg.color: #f0f0f0
window.inactive.button.disabled.image.color: #c0c0c0
window.inactive.button.toggled.unpressed.bg: flat
window.inactive.button.toggled.unpressed.bg.color: #f0f0f0
window.inactive.button.toggled.unpressed.image.color: #909090
window.inactive.button.toggled.pressed.bg: flat
window.inactive.button.toggled.pressed.bg.color: #e0e0e0
window.inactive.button.toggled.pressed.image.color: #707070
window.inactive.button.toggled.hover.bg: flat
window.inactive.button.toggled.hover.bg.color: #e8e8e8
window.inactive.button.toggled.hover.image.color: #707070

# Menu
menu.title.bg: flat
menu.title.bg.color: #ebebeb
menu.title.text.color: #2d2d2d
menu.title.text.shadow.color: #d0d0d0
menu.items.bg: flat
menu.items.bg.color: #f5f5f5
menu.items.text.color: #2d2d2d
menu.items.disabled.text.color: #b0b0b0
menu.items.active.bg: flat
menu.items.active.bg.color: #5294e2
menu.items.active.text.color: #ffffff
menu.items.active.disabled.text.color: #a0c0e8
menu.separator.color: #d0d0d0

# On-screen display
osd.bg: flat
osd.bg.color: #ebebeb
osd.label.text.color: #2d2d2d
osd.border.color: #5294e2
osd.border.width: 1

# Dimensions
padding.width: 6
padding.height: 4
border.width: 1
menu.overlap.x: 0
menu.overlap.y: 0
window.active.title.separator.color: #5294e2
window.inactive.title.separator.color: #d0d0d0

# Font
font: Sans Bold 9
font.shadow: none
font.justify: Center
