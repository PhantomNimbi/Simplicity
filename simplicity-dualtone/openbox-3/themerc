# Simplicity-DualTone Openbox Theme
# Dark titlebar chrome with light window body
# Compatible with: Openbox window manager
# Distros: All major Linux distributions with Openbox/LXDE/LXQt

# Window active colors (dark titlebar)
window.active.title.bg: flat
window.active.title.bg.color: #252525
window.active.title.border.color: #5294e2
window.active.title.shadow.color: #1a1a1a
window.active.label.bg: flat
window.active.label.bg.color: #252525
window.active.label.text.color: #e0e0e0
window.active.handle.bg: flat
window.active.handle.bg.color: #252525
window.active.grip.bg: flat
window.active.grip.bg.color: #5294e2
window.active.border.color: #5294e2

# Window inactive colors (slightly lighter dark titlebar)
window.inactive.title.bg: flat
window.inactive.title.bg.color: #2a2a2a
window.inactive.title.border.color: #404040
window.inactive.title.shadow.color: #1a1a1a
window.inactive.label.bg: flat
window.inactive.label.bg.color: #2a2a2a
window.inactive.label.text.color: #808080
window.inactive.handle.bg: flat
window.inactive.handle.bg.color: #2a2a2a
window.inactive.grip.bg: flat
window.inactive.grip.bg.color: #404040
window.inactive.border.color: #404040

# Button colors (active)
window.active.button.unpressed.bg: flat
window.active.button.unpressed.bg.color: #252525
window.active.button.unpressed.image.color: #e0e0e0
window.active.button.pressed.bg: flat
window.active.button.pressed.bg.color: #1e1e1e
window.active.button.pressed.image.color: #ffffff
window.active.button.hover.bg: flat
window.active.button.hover.bg.color: #303030
window.active.button.hover.image.color: #ffffff
window.active.button.disabled.bg: flat
window.active.button.disabled.bg.color: #252525
window.active.button.disabled.image.color: #606060
window.active.button.toggled.unpressed.bg: flat
window.active.button.toggled.unpressed.bg.color: #303030
window.active.button.toggled.unpressed.image.color: #e0e0e0
window.active.button.toggled.pressed.bg: flat
window.active.button.toggled.pressed.bg.color: #1e1e1e
window.active.button.toggled.pressed.image.color: #ffffff
window.active.button.toggled.hover.bg: flat
window.active.button.toggled.hover.bg.color: #383838
window.active.button.toggled.hover.image.color: #ffffff

# Button colors (inactive)
window.inactive.button.unpressed.bg: flat
window.inactive.button.unpressed.bg.color: #2a2a2a
window.inactive.button.unpressed.image.color: #808080
window.inactive.button.pressed.bg: flat
window.inactive.button.pressed.bg.color: #222222
window.inactive.button.pressed.image.color: #a0a0a0
window.inactive.button.hover.bg: flat
window.inactive.button.hover.bg.color: #303030
window.inactive.button.hover.image.color: #a0a0a0
window.inactive.button.disabled.bg: flat
window.inactive.button.disabled.bg.color: #2a2a2a
window.inactive.button.disabled.image.color: #505050
window.inactive.button.toggled.unpressed.bg: flat
window.inactive.button.toggled.unpressed.bg.color: #2a2a2a
window.inactive.button.toggled.unpressed.image.color: #808080
window.inactive.button.toggled.pressed.bg: flat
window.inactive.button.toggled.pressed.bg.color: #222222
window.inactive.button.toggled.pressed.image.color: #a0a0a0
window.inactive.button.toggled.hover.bg: flat
window.inactive.button.toggled.hover.bg.color: #303030
window.inactive.button.toggled.hover.image.color: #a0a0a0

# Menu (dark chrome)
menu.title.bg: flat
menu.title.bg.color: #252525
menu.title.text.color: #e0e0e0
menu.title.text.shadow.color: #1a1a1a
menu.items.bg: flat
menu.items.bg.color: #2d2d2d
menu.items.text.color: #e0e0e0
menu.items.disabled.text.color: #606060
menu.items.active.bg: flat
menu.items.active.bg.color: #5294e2
menu.items.active.text.color: #ffffff
menu.items.active.disabled.text.color: #a0a0a0
menu.separator.color: #404040

# On-screen display (dark chrome)
osd.bg: flat
osd.bg.color: #252525
osd.label.text.color: #e0e0e0
osd.border.color: #5294e2
osd.border.width: 1

# Dimensions
padding.width: 6
padding.height: 4
border.width: 1
menu.overlap.x: 0
menu.overlap.y: 0
window.active.title.separator.color: #5294e2
window.inactive.title.separator.color: #404040

# Font
font: Sans Bold 9
font.shadow: none
font.justify: Center
