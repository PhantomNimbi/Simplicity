# Simplicity Openbox Theme (Dracula variant)
# Compatible with: Openbox window manager
# Distros: All major Linux distributions with Openbox/LXDE/LXQt

# Window active colors
window.active.title.bg: flat
window.active.title.bg.color: #21222c
window.active.title.border.color: #bd93f9
window.active.title.shadow.color: #191a21
window.active.label.bg: flat
window.active.label.bg.color: #21222c
window.active.label.text.color: #f8f8f2
window.active.handle.bg: flat
window.active.handle.bg.color: #21222c
window.active.grip.bg: flat
window.active.grip.bg.color: #bd93f9
window.active.border.color: #bd93f9

# Window inactive colors
window.inactive.title.bg: flat
window.inactive.title.bg.color: #282a36
window.inactive.title.border.color: #44475a
window.inactive.title.shadow.color: #191a21
window.inactive.label.bg: flat
window.inactive.label.bg.color: #282a36
window.inactive.label.text.color: #6272a4
window.inactive.handle.bg: flat
window.inactive.handle.bg.color: #282a36
window.inactive.grip.bg: flat
window.inactive.grip.bg.color: #44475a
window.inactive.border.color: #44475a

# Button colors (active)
window.active.button.unpressed.bg: flat
window.active.button.unpressed.bg.color: #21222c
window.active.button.unpressed.image.color: #f8f8f2
window.active.button.pressed.bg: flat
window.active.button.pressed.bg.color: #1e1f29
window.active.button.pressed.image.color: #ffffff
window.active.button.hover.bg: flat
window.active.button.hover.bg.color: #383a4b
window.active.button.hover.image.color: #ffffff
window.active.button.disabled.bg: flat
window.active.button.disabled.bg.color: #21222c
window.active.button.disabled.image.color: #44475a
window.active.button.toggled.unpressed.bg: flat
window.active.button.toggled.unpressed.bg.color: #383a4b
window.active.button.toggled.unpressed.image.color: #f8f8f2
window.active.button.toggled.pressed.bg: flat
window.active.button.toggled.pressed.bg.color: #1e1f29
window.active.button.toggled.pressed.image.color: #ffffff
window.active.button.toggled.hover.bg: flat
window.active.button.toggled.hover.bg.color: #44475a
window.active.button.toggled.hover.image.color: #ffffff

# Button colors (inactive)
window.inactive.button.unpressed.bg: flat
window.inactive.button.unpressed.bg.color: #282a36
window.inactive.button.unpressed.image.color: #6272a4
window.inactive.button.pressed.bg: flat
window.inactive.button.pressed.bg.color: #21222c
window.inactive.button.pressed.image.color: #a0a0b0
window.inactive.button.hover.bg: flat
window.inactive.button.hover.bg.color: #383a4b
window.inactive.button.hover.image.color: #a0a0b0
window.inactive.button.disabled.bg: flat
window.inactive.button.disabled.bg.color: #282a36
window.inactive.button.disabled.image.color: #44475a
window.inactive.button.toggled.unpressed.bg: flat
window.inactive.button.toggled.unpressed.bg.color: #282a36
window.inactive.button.toggled.unpressed.image.color: #6272a4
window.inactive.button.toggled.pressed.bg: flat
window.inactive.button.toggled.pressed.bg.color: #21222c
window.inactive.button.toggled.pressed.image.color: #a0a0b0
window.inactive.button.toggled.hover.bg: flat
window.inactive.button.toggled.hover.bg.color: #383a4b
window.inactive.button.toggled.hover.image.color: #a0a0b0

# Menu
menu.title.bg: flat
menu.title.bg.color: #21222c
menu.title.text.color: #f8f8f2
menu.title.text.shadow.color: #191a21
menu.items.bg: flat
menu.items.bg.color: #282a36
menu.items.text.color: #f8f8f2
menu.items.disabled.text.color: #6272a4
menu.items.active.bg: flat
menu.items.active.bg.color: #bd93f9
menu.items.active.text.color: #f8f8f2
menu.items.active.disabled.text.color: #a0a0b0
menu.separator.color: #44475a

# On-screen display
osd.bg: flat
osd.bg.color: #21222c
osd.label.text.color: #f8f8f2
osd.border.color: #bd93f9
osd.border.width: 1

# Dimensions
padding.width: 6
padding.height: 4
border.width: 1
menu.overlap.x: 0
menu.overlap.y: 0
window.active.title.separator.color: #bd93f9
window.inactive.title.separator.color: #44475a

# Font
font: Sans Bold 9
font.shadow: none
font.justify: Center
